# ============================================================================
# Phase 4 — Entra ID + SharePoint (Microsoft Graph)
# Copier ce fichier en `.env` (à la racine) et remplir les valeurs.
# ⚠ NE PAS COMMITER `.env` — il est déjà ignoré par .gitignore.
# Tant que ces valeurs sont vides, l'application tourne en MODE LOCAL (IndexedDB seul),
# exactement comme aujourd'hui. Une fois remplies, elle bascule sur SharePoint.
# (Variables préfixées VITE_ pour être exposées au navigateur par Vite.)
# ============================================================================

# --- Entra ID (Azure AD) — application enregistrée de type "SPA" ---
# Onglet "Overview" de l'app dans le portail Entra :
VITE_ENTRA_TENANT_ID=
VITE_ENTRA_CLIENT_ID=
# Optionnel. Par défaut = origine courante (http://localhost:5173 en dev,
# puis l'URL Azure Static Web Apps en production). À renseigner seulement si besoin.
VITE_ENTRA_REDIRECT_URI=

# --- SharePoint (site "PPT ALHEE") ---
# Hôte SharePoint, SANS https://  (ex. alhee.sharepoint.com)
VITE_SP_HOSTNAME=
# Chemin serveur-relatif du site (ex. /sites/PPTALHEE)
VITE_SP_SITE_PATH=
# Noms de la liste-index et de la bibliothèque (laisser tels quels sauf besoin) :
VITE_SP_INDEX_LIST=PPT-Index
VITE_SP_DATA_LIBRARY=PPT-Data
